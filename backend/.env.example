# ═══════════════════════════════════════════════════════════
# GUAP-BOT BACKEND CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Broker (OANDA) ──────────────────────────────────────
OANDA_API_KEY=your-oanda-api-key-here
OANDA_ACCOUNT_ID=your-account-id-here
OANDA_BASE_URL=https://api-fxpractice.oanda.com/v3
OANDA_STREAM_URL=https://stream-fxpractice.oanda.com/v3
OANDA_IS_DEMO=true

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/guapbot
REDIS_URL=redis://localhost:6379

# ─── Strategy ────────────────────────────────────────────
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
TAKE_PROFIT_PIPS=8
STOP_LOSS_PIPS=5
TRAILING_STOP_ENABLED=false
TRAILING_STOP_PIPS=3
TRADING_SYMBOL=XAU_USD
TRADING_TIMEFRAME=1m

# ─── Risk Management ────────────────────────────────────
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_DRAWDOWN=0.15
MAX_OPEN_POSITIONS=3
MIN_RISK_REWARD_RATIO=1.5
MAX_SLIPPAGE_PIPS=2
STALE_POSITION_TIMEOUT_MINUTES=30

# ─── Trading Schedule ───────────────────────────────────
TRADING_DAYS=Mon,Tue,Wed,Thu,Fri
TRADING_HOURS_START=08:00
TRADING_HOURS_END=17:00
TRADING_TIMEZONE=UTC
POSITION_SIZING=percentage

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info

# ─── Server ──────────────────────────────────────────────
PORT=3001
